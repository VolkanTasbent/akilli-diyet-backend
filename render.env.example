# Build (Render servisi hâlâ "Node" ise JDK yok → script kullan):
#   bash scripts/render-build.sh
# Start Command:
#   java -Dserver.port=$PORT -jar target/*.jar
#
# Runtime'ı Docker veya Java yaptıysan: Dockerfile / ./mvnw yeter; bu script gerekmez.

# Render "Add from .env" icin: kopyala, asagidaki YOUR_... degerlerini doldur, yapistir.
# Bu dosyayi git'e commit edebilirsin; gercek sifreleri render.env'e yaz (gitignore).
# SPRING_DATASOURCE_URL jdbc:postgresql ile basliyorsa prod profili otomatik acilir; yine de asagidaki satiri birakabilirsin.

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-ancient-dust-alzzpopg-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=YOUR_NEON_PASSWORD
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_48_OR_SIMILAR
APP_CORS_ORIGINS=https://YOUR_FRONTEND_URL
APP_FRONTEND_BASE_URL=https://YOUR_FRONTEND_URL
APP_AVATAR_DIR=/tmp/akilli-avatars
